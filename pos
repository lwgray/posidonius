#!/bin/bash

# Posidonius Experiment Dashboard CLI
# Commands: start, stop, restart, status, logs

set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Configuration
PORT=${POSIDONIUS_PORT:-8420}
HOST=${POSIDONIUS_HOST:-127.0.0.1}
VENV_DIR="$SCRIPT_DIR/.venv"
PID_FILE="/tmp/posidonius.pid"
LOG_FILE="/tmp/posidonius.log"

# Activate virtualenv
activate_venv() {
    if [ -d "$VENV_DIR" ]; then
        source "$VENV_DIR/bin/activate"
    else
        echo -e "${RED}Error: virtualenv not found at $VENV_DIR${NC}"
        echo "Run: python -m venv .venv && source .venv/bin/activate && pip install -e '.[dev]'"
        exit 1
    fi
}

is_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            return 0
        else
            # Stale PID file
            rm -f "$PID_FILE"
            return 1
        fi
    fi
    return 1
}

start_server() {
    if is_running; then
        echo -e "${YELLOW}Posidonius is already running (PID: $(cat $PID_FILE))${NC}"
        echo "  Run './pos stop' first or './pos restart'"
        return 0
    fi

    activate_venv

    echo -e "${BLUE}Starting Posidonius...${NC}"

    # Parse extra args
    EXTRA_ARGS=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)
                PORT="$2"
                shift 2
                ;;
            --host)
                HOST="$2"
                shift 2
                ;;
            --experiments-dir)
                EXTRA_ARGS="$EXTRA_ARGS --experiments-dir $2"
                shift 2
                ;;
            --templates-dir)
                EXTRA_ARGS="$EXTRA_ARGS --templates-dir $2"
                shift 2
                ;;
            -f|--foreground)
                echo -e "${BLUE}Running in foreground (Ctrl+C to stop)${NC}"
                echo -e "  Dashboard: http://${HOST}:${PORT}"
                python -m posidonius --host "$HOST" --port "$PORT" $EXTRA_ARGS
                return $?
                ;;
            *)
                shift
                ;;
        esac
    done

    # Start as daemon
    python -m posidonius --host "$HOST" --port "$PORT" $EXTRA_ARGS > "$LOG_FILE" 2>&1 &
    PID=$!
    echo "$PID" > "$PID_FILE"

    # Wait for server to be ready
    echo -n "  Waiting for server"
    for i in {1..15}; do
        if curl -s "http://${HOST}:${PORT}/health" > /dev/null 2>&1; then
            echo -e " ${GREEN}✓${NC}"
            echo ""
            echo -e "${GREEN}Posidonius started successfully${NC}"
            echo -e "  PID:       ${PID}"
            echo -e "  Dashboard: ${BLUE}http://${HOST}:${PORT}${NC}"
            echo -e "  Logs:      ${LOG_FILE}"
            echo ""
            echo "Run './pos status' to check service status"
            echo "Run './pos logs' to view logs"
            echo "Run './pos stop' to stop"
            return 0
        fi
        echo -n "."
        sleep 1
    done

    echo -e " ${RED}✗${NC}"
    echo -e "${RED}Failed to start. Check logs: tail -f ${LOG_FILE}${NC}"
    rm -f "$PID_FILE"
    return 1
}

stop_server() {
    if ! is_running; then
        echo -e "${YELLOW}Posidonius is not running${NC}"
        return 0
    fi

    PID=$(cat "$PID_FILE")
    echo -e "${BLUE}Stopping Posidonius (PID: ${PID})...${NC}"

    # Graceful shutdown
    kill "$PID" 2>/dev/null

    # Wait for stop
    for i in {1..10}; do
        if ! kill -0 "$PID" 2>/dev/null; then
            echo -e "${GREEN}✓ Posidonius stopped${NC}"
            rm -f "$PID_FILE"
            return 0
        fi
        sleep 0.5
    done

    # Force kill
    echo -e "${YELLOW}Forcing stop...${NC}"
    kill -9 "$PID" 2>/dev/null
    rm -f "$PID_FILE"
    echo -e "${GREEN}✓ Posidonius stopped (forced)${NC}"
}

show_status() {
    echo -e "${BLUE}Posidonius Dashboard Status${NC}"
    echo "==========================="

    if is_running; then
        PID=$(cat "$PID_FILE")
        echo -e "Server: ${GREEN}Running${NC} (PID: ${PID}, Port: ${PORT})"

        # Health check
        if curl -s "http://${HOST}:${PORT}/health" > /dev/null 2>&1; then
            echo -e "Health: ${GREEN}✓ Healthy${NC}"
        else
            echo -e "Health: ${RED}✗ Unhealthy${NC}"
        fi

        echo -e "URL:    ${BLUE}http://${HOST}:${PORT}${NC}"
    else
        echo -e "Server: ${RED}Stopped${NC}"
    fi

    echo ""
    echo "Logs: tail -f ${LOG_FILE}"
}

show_logs() {
    if [ "$1" == "--tail" ] || [ "$1" == "-n" ]; then
        tail -n "${2:-50}" "$LOG_FILE"
    elif [ "$1" == "--follow" ] || [ "$1" == "-f" ]; then
        tail -f "$LOG_FILE"
    else
        tail -f "$LOG_FILE"
    fi
}

show_help() {
    cat << EOF
${BLUE}Posidonius Experiment Dashboard CLI${NC}

Usage: pos <command> [options]

Commands:
  start [options]    Start the dashboard server
  stop               Stop the server
  restart            Restart the server
  status             Show server status
  logs [-f|-n N]     Show logs (default: follow)
  help               Show this help message

Start Options:
  --port PORT            Port to listen on (default: 8420, or \$POSIDONIUS_PORT)
  --host HOST            Host to bind to (default: 127.0.0.1, or \$POSIDONIUS_HOST)
  --experiments-dir DIR  Base directory for experiment output
  --templates-dir DIR    Path to Marcus experiment templates
  -f, --foreground       Run in foreground (not as daemon)

Examples:
  ./pos start                    # Start on default port 8420
  ./pos start --port 9000        # Start on custom port
  ./pos start -f                 # Run in foreground
  ./pos restart                  # Restart the server
  ./pos status                   # Check what's running
  ./pos logs -n 50               # View last 50 lines
  ./pos stop                     # Stop the server

EOF
}

# Main command handler
case "$1" in
    start)
        shift
        start_server "$@"
        ;;
    stop)
        stop_server
        ;;
    restart)
        echo -e "${BLUE}Restarting Posidonius...${NC}"
        stop_server
        sleep 1
        shift
        start_server "$@"
        ;;
    status)
        show_status
        ;;
    logs)
        shift
        show_logs "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    "")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
