[run]
source = posidonius/
omit =
    */tests/*
    */test_*
    __pycache__
    .venv

[report]
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    if TYPE_CHECKING:

[html]
directory = htmlcov/
